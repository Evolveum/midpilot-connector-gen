APP__TITLE="Smart Integration Microservice (DEV)"
APP__LIVE_RELOAD=true
LOGGING__LEVEL=info
LOGGING__COLORS=true

# llm
LLM__OPENAI_API_KEY=myopenrouterkey # OR vLLM API KEY

# langfuse configuration
#LANGFUSE__HOST=langfuse-host
#LANGFUSE__SECRET_KEY=langfusehost-secret-key
#LANGFUSE__PUBLIC_KEY=langfusehost-public-key
#LANGFUSE__TRACING_ENABLED=true
#LANGFUSE__ENVIRONMENT=dev-myname
#LANGFUSE__CA_CERT_FILE=/path/to/cert


# search method
SEARCH__METHOD_NAME=methodname #  either "ddgs" or "brave"

# brave configuration
BRAVE__API_KEY=mybravekey
BRAVE__ENDPOINT=myendpoint

# DATABASE CONFIGURATION
DATABASE__HOST=localhost # for local deployment
# DATABASE__HOST=db # for docker deployment
DATABASE__INT_PORT=5432
DATABASE__EXT_PORT=5433
DATABASE__NAME=db_name
DATABASE__USER=user
DATABASE__PASSWORD=password

# Full database URL (used by Python/SQLAlchemy)
DATABASE__URL=postgresql+asyncpg://${DATABASE__USER}:${DATABASE__PASSWORD}@${DATABASE__HOST}:${DATABASE__EXT_PORT}/${DATABASE__NAME}